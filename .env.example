# Runtime mode. Production requires WEB_STATIC_ROOT to point to Cocos Web build output.
NODE_ENV=development

# Node.js backend listen port.
PORT=4173

# File-backed player/session state path. Keep the real production path outside Git.
GAME_DATA_FILE=server/data/game-state.json

# Production only: Cocos Web build output. Leave blank for local debug harness.
WEB_STATIC_ROOT=
